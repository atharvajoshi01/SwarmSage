# ===========================================
# SwarmSage Environment Configuration
# ===========================================

# LLM API Configuration (any OpenAI-compatible API)
# Recommended: OpenAI GPT-4o-mini, or Alibaba Qwen-plus
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o-mini

# Zep Cloud Configuration (knowledge graph & memory)
# Free tier available at: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# Optional: Boost LLM for faster processing (leave unset to use main LLM)
# LLM_BOOST_API_KEY=your_api_key_here
# LLM_BOOST_BASE_URL=your_base_url_here
# LLM_BOOST_MODEL_NAME=your_model_name_here

# Optional: Simulation settings
# OASIS_DEFAULT_MAX_ROUNDS=10
# REPORT_AGENT_MAX_TOOL_CALLS=5
# REPORT_AGENT_MAX_REFLECTION_ROUNDS=2

# Optional: Flask settings
# FLASK_DEBUG=True
# FLASK_HOST=0.0.0.0
# FLASK_PORT=5001
